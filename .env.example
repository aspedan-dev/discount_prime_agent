# Google AI Studio API key (NOT Vertex AI) -- https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-studio-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Optional model overrides
DPA_ANALYTICS_MODEL=gemini-2.5-flash
DPA_STRATEGY_MODEL=gemini-2.5-pro

# Pipeline defaults (overridable via CLI flags)
DPA_DATA_PATH=data/sample-data-mongo.json
DPA_OUT_DIR=outputs/
DPA_MIN_UNITS=20
